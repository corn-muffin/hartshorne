\begin{enumerate}
  \item[7.1.] {
      Let $(X,\O_X)$ be a locally ringed space, and let $f:\L\to \M$ be a surjective map of invertible sheaves on $X$.
      Show that $f$ is an isomorphism.
      [\emph{Hint:} Reduce to a question of modules over a local ring by looking at the stalks.]
    }
\end{enumerate}

\begin{proof}
  It suffices to show $f_x:\L_x\twoheadrightarrow \M_x$ is an isomorphism of $\O_{X,x}$-modules.
  $\L$, $\M$ invertible implies $\L_x\cong \M_x\cong \O_{X,x}$, so it suffices to show that a surjective map $f:\O_{X,x}\twoheadrightarrow\O_{X,x}$ is an isomorphism.
  We have $a\in \O_{X,x}$ such that $f(a) = 1$, so $f(1)=a^{-1}$ is a unit, whence $0=f(b)=bf(1)$ implies $b=0$, showing injectivity.
\end{proof}

\begin{enumerate}
  \item[7.2.] {
      Let $X$ be a scheme over a field $k$.
      Let $\L$ be an invertible sheaf on $X$, and let $\{s_0,\ldots,s_n\}$ and $\{t_0,\ldots,t_m\}$ be two sets of sections of $\L$, which generate the same subspace $V\subset \Gamma(X,\L)$, and which generate the sheaf $\L$ at every point.
      Suppose $n\leqs m$.
      Show that the corresponding morphisms $\phi:X\to \PP^n_k$ and $\psi:X\to \PP^m_k$ differ by a suitable linear projection $\PP^m-L\to \PP^n$, and an automorphism of $\PP^n$, where $L$ is a linear subspace of dimension $m-n-1$.
    }
\end{enumerate}

\begin{enumerate}
  \item[7.3.] {
      Let $\phi:\PP^n_k\to \PP^m_k$ be a morphism.
      Then:
      \begin{enumerate}
        \item either $\phi(\PP^n)=\{*\}$ or $m\geqs n$ and $\dim \phi(\PP^n)=n$;
        \item in the second case, $\phi$ can be obtained as the composition of (1) a $d$-uple embedding $\PP^n\to \PP^N$ for a uniquely determined $d\geqs 1$, (2) a linear projection $\PP^N-L\to \PP^m$, and (3) an automorphism of $\PP^m$.
      \end{enumerate}
    }
\end{enumerate}

\begin{enumerate}
  \item[7.5.] {
      Establish the following properties of ample and very ample invertible sheaves on a noetherian scheme $X$.
      $\L$, $\M$ will denote invertible sheaves, and for (d), (e) we assume furthermore that $X$ is of finite type over a noetherian ring $A$.
      \begin{enumerate}
        \item If $\L$ is ample and $\M$ is generated by global sections, then $\L\otimes \M$ is ample.
        \item If $\L$ is ample and $\M$ is arbitrary, then $\M\otimes \L^n$ is ample for $n\gg0$.
        \item If $\L$, $\M$ are both ample, so is $\L\otimes \M$.
        \item If $\L$ is very ample and $\M$ is generated by global sections, then $\L\otimes \M$ is very ample.
        \item If $\L$ is ample, then there is an $n_0>0$ such that $\L^n$ is very ample for all $n\geqs n_0$.
      \end{enumerate}
    }
\end{enumerate}

\begin{proof}
  (a) Let $\F$ be a coherent sheaf on $X$, take global generators $s_0,\ldots, s_r\in \Gamma(X,\M)$, and let $n_0>0$ such that $\F\otimes \L^n$ is globally generated for all $n\geqs n_0$.
  Then, for any $n\geqs n_0$, $\M^n$ is globally generated by the $s_{i_1}\otimes\cdots \otimes s_{i_n}\in \Gamma(X,\M)$.
  Choosing some generators $t_0,\ldots, t_k\in \Gamma(X,\F\otimes \L^n)$, we have generators 
  \[
    t_{i_0}\otimes s_{i_1}\otimes\cdots\otimes s_{i_n}\in \Gamma(X,\F\otimes (\L\otimes\M)^n).
  \]
  These sections do indeed generate, because $(\F\otimes (\L\otimes \M)^n)_x\cong \F_x\otimes (\L_x\otimes \M_x)^n$.

  (b) Let $n_0>0$ such that $\M\otimes \L^n$  is globally generated whenever $n\geqs n_0$.
  We will show that $\M\otimes \L^{n_0+1}$ is ample.
  Fix $\F\in\Coh_X$, and take $n_1>0$ such that $\F\otimes \L^n$ is globally generated for all $n\geqs n_1$.
  Then, for any $n\geqs n_1$,
  \begin{align*}
    \F\otimes (\M\otimes \L^{n_0+1})^n 
    &\cong (\F\otimes \L^n)\otimes (\M\otimes \L^{n_0})^n
  \end{align*}
  is a tensor product of globally generated spaces, hence globally generated itself.

  (c) Fix $\F\in \Coh_X$, take $n_0>0$ such that $\F\otimes \L^n$ is globally generated whenever $n\geqs n_0$, and take $n_1>0$ such that $\M\otimes \L^n$ is globally generated whenever $n\geqs n_1$.
  Then, whenever $n\geqs \max\{n_0+1,n_1\}$, we have that
  \[
    \F\otimes (\M\otimes \L)^n 
    = (\F\otimes \M^{n-1})\otimes (\M\otimes\L^n)
  \] 
  is globally generated.

  (d) Take generators $s_0,\ldots, s_m\in \Gamma(X,\L)$ and $t_0,\ldots, s_n\in \Gamma(X,\M)$, along with corresponding maps $\phi:X\to \PP^m$ and $\psi:X\to \PP^n$ such that 
  \begin{align*}
    \L &\cong \phi^*(\O_{\PP^m}(1)),
    \;\;\;\M \cong \psi^*(\O_{\PP^n}(1)).
  \end{align*}
  Consider the Segre embedding $\sigma:\PP^m\times \PP^n\to \PP^N$, and the composition %has $\sigma^*(\O_{\PP^N}(1))\cong \O(1)\cong p_1^*(\O_{\PP^m}(1))\otimes p_2^*(\O_{\PP^n}(1))$.
  \[
    \begin{tikzcd}
      X\ar[r,"\Delta"] & X\times X \ar[r, "\phi\times \psi"] & \PP^m\times \PP^n \ar[r,"\sigma"]&\PP^N.
    \end{tikzcd}
  \] 
  Denoting the above map $f:X\to \PP^N$, we have
  \begin{align*}
    f^*(\O_{\PP^N}) 
    &\cong ((\phi\times\psi)\circ\Delta)^*(p_1^*(\O_{\PP^m}(1))\otimes p_2^*(\O_{\PP^n}(1))) \\
    &\cong \phi^*(\O_{\PP^n}(1))\otimes \psi^*(\O_{\PP^m}(1)) \\
    &\cong \L\otimes \M
  \end{align*}
  by (Ex. 5.11).
  It suffices, then, to show that $g:=(\phi\times \psi)\circ \Delta$ is a closed immersion.

  By (7.2), we have each $X_i:=X_{s_i}$ is affine, with each
  \begin{align*}
    A[z_0,\ldots, z_m] 
    &\longrightarrow \Gamma(X_i,\O_{X_i}) \\
    z_j
    &\longmapsto s_j/s_i
  \end{align*}
  surjective, where $z_j:=x_j/x_i$.
  Consider $Y_j:= X_{t_j}$.%todo justify that $t_j$ is really an element of $\O_X$.
  Then $X_i\cap Y_j= D_{X_i}(t_j)$ is affine, so surjectivity of the map
  \begin{align*}
    A[w_0,\ldots, w_n] 
    &\longrightarrow \Gamma(Y_j,\O_{Y_j}) \\
    w_k
    &\longmapsto t_k/t_j
  \end{align*}
  gives us surjectivity of the restricted map $A[w_0,\ldots,w_n]\to \Gamma(X_i\cap Y_j,\O_{X_i\cap Y_j})$.
  Hence, the map
  \begin{align*}
    A[z_0w_0,\ldots,z_mw_n]
    &\longrightarrow \Gamma(X_i\cap Y_j,\O_{X_i\cap Y_j}) \\
    z_kw_l&\longmapsto \frac{x_ky_l}{x_iy_j}
  \end{align*}
  is surjective.

  We have $X_i\cap Y_j= g^{-1}(U_{ij})=g^{-1}(D_+(x_iy_j))$, so that $g$ is locally a closed immersion on the base.
  We conclude that, in fact $g:X\to \PP^m\times \PP^n$ is a a closed immersion, whence $\sigma\circ g:X\to \PP^N$ is a closed immersion with $\L\otimes \M\cong (\sigma\circ g)^*(\PP^N)$.
  That is, $\L\otimes \M$ is very ample with respect to $A$.

  (e) Take some fixed $m>0$ such that $\L^m$ is very ample by (7.6), and take $n_0>0$ such that $\O_X\otimes \L^n\cong \L^n$ is globally generated for all $n\geqs n_0$.
  Then, for all $n\geqs m+n_0$, we have that $\L^n\cong \L^m\otimes \L^{n-m}$ is very ample by (d).
\end{proof}

\begin{enumerate}
  \item[7.7.] {
      \emph{Some Rational Surfaces.}
      Let $X=\PP^2_k$, and let $|D|$ be the complete linear system of all divisors of degree 2 on $X$ (conics).
      $D$ corresponds to the invertible sheaf $\O(2)$, whose space of global sections has a basis $x^2,y^2,z^2,xy,xz,yz$, where $x,y,z$ are the homogneous coorrdinates of $X$.
      \begin{enumerate}
        \item The complete linear system $|D|$ gives an embedding of $\PP^2$ in $\PP^5$, whose image is the veronese surfaces (I, Ex. 2.13).
        \item Show that the subsystem defined by $x^2,y^2,z^2,y(x-z),(x-y)z$ gives a closed immersion of $X$ into $\PP^4$.
          The image is called the \emph{Veronese surface} in $\PP^4$. Cf. (IV, Ex. 3.11).
        \item Let $\fr{d}\subset |D|$ be the linear system of all conic passing through a fixed point $p$.
          Then $\fr d$ gives an imersion of $U=X-p$ into $\PP^4$.
          Furthermore, if we blow up $p$ to get a surface $\wtilde X$, then this map extends to give a closed immersion of $\wtilde X$ in $\PP^4$.
          Show that $\wtilde X$ is a surface of degree 3 in $\PP^4$, and that the lines in $X$ through $p$ are transformed into straight lines in $\wtilde X$ which do not meet.
          $\wtilde X$ is the union of all these lines, so we say $\wtilde X$ is a \emph{ruled surface} (V, 2.19.1).
      \end{enumerate}
    }
\end{enumerate}

